        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json, text/event-stream"
          },
          {
            "key": "MCP-Session-Id",
            "value": "{{mcp_session_id}}"
          },
          {
            "key": "MCP-Protocol-Version",
            "value": "{{mcp_protocol_version}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 4,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"web_read\",\n    \"arguments\": {\n      \"url\": \"https://revdev.tech\"\n    }\n  }\n}"
        },
        "url": {
          "raw": "{{protocol}}://{{baseUrl}}:7021/mcp",
          "protocol": "{{protocol}}",
          "host": [
            "{{baseUrl}}"
          ],
          "port": "7021",
          "path": [
            "mcp"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "pm.test(\"Status code is 200\", function () {\r",
          "    pm.response.to.have.status(200);\r",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "mcp_protocol_version",
      "value": "2025-11-25"
    },
    {
      "key": "mcp_session_id",
      "value": ""
    },
    {
      "key": "baseUrl",
      "value": "localhost",
      "type": "default"
    },
    {
      "key": "protocol",
