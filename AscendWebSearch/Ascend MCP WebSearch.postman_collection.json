{
  "info": {
    "_postman_id": "adb46d09-90c2-4762-8ce4-2df05eae35b7",
    "name": "Ascend MCP WebSearch",
    "description": "Automated test suite for AscendWebSearch MCP Server.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "6370134"
  },
  "item": [
    {
      "name": "Initialize",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Automatically extract header and save to collection variable",
              "pm.collectionVariables.set(\"mcp_session_id\", pm.response.headers.get(\"MCP-Session-Id\"));",
              "",
              "pm.test(\"Session ID is set\", function () {",
              "    pm.expect(pm.collectionVariables.get(\"mcp_session_id\")).to.not.be.undefined;",
              "    pm.expect(pm.collectionVariables.get(\"mcp_session_id\")).to.not.be.empty;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json, text/event-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"{{mcp_protocol_version}}\",\n    \"capabilities\": {},\n    \"clientInfo\": { \"name\": \"postman-client\", \"version\": \"0.1.0\" }\n  }\n}"
        },
        "url": {
          "raw": "{{protocol}}://{{baseUrl}}:7021/mcp",
          "protocol": "{{protocol}}",
          "host": [
            "{{baseUrl}}"
          ],
          "port": "7021",
          "path": [
            "mcp"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Tools",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json, text/event-stream"
          },
          {
            "key": "MCP-Session-Id",
            "value": "{{mcp_session_id}}"
          },
          {
            "key": "MCP-Protocol-Version",
            "value": "{{mcp_protocol_version}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}"
        },
        "url": {
          "raw": "{{protocol}}://{{baseUrl}}:7021/mcp",
          "protocol": "{{protocol}}",
          "host": [
            "{{baseUrl}}"
          ],
          "port": "7021",
          "path": [
            "mcp"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Web Search",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json, text/event-stream"
          },
          {
            "key": "MCP-Session-Id",
            "value": "{{mcp_session_id}}"
          },
          {
            "key": "MCP-Protocol-Version",
            "value": "{{mcp_protocol_version}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 3,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"web_search\",\n    \"arguments\": {\n      \"query\": \"AscendAI project\",\n      \"limit\": 3\n    }\n  }\n}"
        },
        "url": {
          "raw": "{{protocol}}://{{baseUrl}}:7021/mcp",
          "protocol": "{{protocol}}",
          "host": [
            "{{baseUrl}}"
          ],
          "port": "7021",
          "path": [
            "mcp"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Web Read",
