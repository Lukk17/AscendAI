    {
      "name": "Insert Memory",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var rawText = pm.response.text();\r",
              "// Split by \"data: \" to handle Server-Sent Events\r",
              "var chunks = rawText.split(\"data: \");\r",
              "\r",
              "var memoryId = null;\r",
              "\r",
              "for (var i = 0; i < chunks.length; i++) {\r",
              "    var chunk = chunks[i].trim();\r",
              "    if (chunk.length === 0) continue;\r",
              "    \r",
              "    try {\r",
              "        var jsonData = JSON.parse(chunk);\r",
              "        \r",
              "        if (jsonData.result && jsonData.result.structuredContent) {\r",
              "            // \"result\" -> \"structuredContent\" -> \"result\"\r",
              "            var memoryIds = jsonData.result.structuredContent.result;\r",
              "\r",
              "            if (memoryIds && memoryIds.length > 0) {\r",
              "                memoryId = memoryIds[0].id; // Extract inner ID\r",
              "                \r",
              "                // Save to Collection Variable\r",
              "                pm.collectionVariables.set(\"memoryId\", memoryId);\r",
              "                console.log(\"Extracted Memory ID: \" + memoryId);\r",
              "                break; // Found it, stop parsing\r",
              "            }\r",
              "        }\r",
              "    } catch (e) {\r",
              "        // Ignore non-JSON chunks (like \"event: message\")\r",
              "    }\r",
              "}\r",
              "\r",
              "if (!memoryId) {\r",
              "    console.log(\"No memory ID found in stream response\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json, text/event-stream"
          },
          {
            "key": "MCP-Session-Id",
            "value": "{{mcp_session_id}}"
          },
          {
            "key": "MCP-Protocol-Version",
            "value": "{{mcp_protocol_version}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 3,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"memory_insert\",\n    \"arguments\": {\n      \"user_id\": \"{{userId}}\",\n      \"text\": \"This is a test memory: red dolphin\"\n    }\n  }\n}"
        },
        "url": {
          "raw": "{{protocol}}://{{baseUrl}}:7020/mcp",
