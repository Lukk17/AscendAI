# AscendAI — secrets and per-deployment overrides.
# Copy to `.env` (gitignored) and fill in the keys you actually use.
# `docker compose` reads this file automatically from the repo root.

# ─── Provider API keys (AscendAgent, AscendMemory, AudioScribe) ───
OPENAI_API_KEY=
ASCEND_ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=

# ─── AudioScribe ───
# Hugging Face Inference API token. Required only for the HF transcription backend.
HF_TOKEN=

# ─── AscendWebSearch ───
# Ngrok auth token for the NoVNC CAPTCHA-intervention tunnel. Required only
# when running the scrapper stack with the ngrok-ascend-web-search profile.
NGROK_AUTHTOKEN=

# ─── AscendAgent — chat-history backend toggles ───
# Both default to `true` in docker-compose.yaml. Uncomment and set to `false`
# to opt the agent out of that persistence layer. With BOTH set to false the
# agent retains no turn-by-turn transcripts and relies entirely on semantic
# memory (Qdrant via AscendMemory) for cross-turn coherence.
# The env-var names use Spring Boot's canonical form for kebab-case
# properties — hyphens removed: `CHATHISTORY`, not `CHAT_HISTORY`.
# APP_MEMORY_CHATHISTORY_REDIS_ENABLED=true
# APP_MEMORY_CHATHISTORY_POSTGRES_ENABLED=true

# ─── AscendAgent — chat-history compaction ───
# Async summarisation of older turns once a conversation crosses the configured
# threshold (default: 20 turns OR 50% of provider context). Set to false to keep
# raw history forever. Per-provider compaction-model map lives in
# AscendAgent/src/main/resources/application.yaml under
# app.memory.chat-history.compaction.provider-defaults.
# APP_MEMORY_CHATHISTORY_COMPACTION_ENABLED=true
