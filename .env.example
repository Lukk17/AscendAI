# AscendAI — secrets and per-deployment overrides.
# Copy to `.env` (gitignored) and fill in the keys you actually use.
# `docker compose` reads this file automatically from the repo root.

# ─── Provider API keys (AscendAgent, AscendMemory, AudioScribe) ───
OPENAI_API_KEY=
ASCEND_ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=

# ─── AudioScribe ───
# Hugging Face Inference API token. Required only for the HF transcription backend.
HF_TOKEN=

# ─── AscendWebSearch ───
# Ngrok auth token for the NoVNC CAPTCHA-intervention tunnel. Required only
# when running the scrapper stack with the ngrok-ascend-web-search profile.
NGROK_AUTHTOKEN=
