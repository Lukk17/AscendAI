  "item": [
    {
      "name": "Initialize",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Automatically extract header and save to collection variable",
              "pm.collectionVariables.set(\"mcp_session_id\", pm.response.headers.get(\"MCP-Session-Id\"));",
              "",
              "pm.test(\"Session ID is set\", function () {",
              "    pm.expect(pm.collectionVariables.get(\"mcp_session_id\")).to.not.be.undefined;",
              "    pm.expect(pm.collectionVariables.get(\"mcp_session_id\")).to.not.be.empty;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json, text/event-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"{{mcp_protocol_version}}\",\n    \"capabilities\": {},\n    \"clientInfo\": { \"name\": \"postman-client\", \"version\": \"0.1.0\" }\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:7017/mcp",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "7017",
          "path": [
            "mcp"
          ]
        }
      },
      "response": []
