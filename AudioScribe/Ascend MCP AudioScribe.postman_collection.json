  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "pm.test(\"Status code is 200\", function () {\r",
          "    pm.response.to.have.status(200);\r",
          "});\r",
          "\r",
          "pm.test(\"MCP Response is Successful\", function () {\r",
          "    var body = pm.response.text();\r",
          "    var jsonData = null;\r",
          "\r",
          "    // Handle Server-Sent Events (SSE) format if present\r",
          "    if (body.trim().startsWith(\"event:\")) {\r",
          "        // Extract the JSON from the \"data:\" line\r",
          "        var lines = body.split('\\n');\r",
          "        for (var i = 0; i < lines.length; i++) {\r",
          "            if (lines[i].startsWith(\"data: \")) {\r",
          "                try {\r",
          "                    jsonData = JSON.parse(lines[i].substring(6));\r",
          "                } catch (e) {\r",
          "                    pm.expect.fail(\"Failed to parse SSE JSON data: \" + e.message);\r",
          "                }\r",
          "                break; \r",
          "            }\r",
          "        }\r",
          "    } else {\r",
          "        // Standard JSON response\r",
          "        try {\r",
          "            jsonData = pm.response.json();\r",
          "        } catch (e) {\r",
          "            pm.expect.fail(\"Failed to parse JSON response: \" + e.message);\r",
          "        }\r",
          "    }\r",
          "\r",
          "    if (!jsonData) {\r",
          "        pm.expect.fail(\"No valid JSON data found in response\");\r",
          "        return;\r",
          "    }\r",
          "    \r",
          "    // Check for JSON-RPC and MCP errors...\r",
          "    if (jsonData.error) pm.expect.fail(\"JSON-RPC Error: \" + jsonData.error.message);\r",
          "    if (jsonData.result && jsonData.result.isError) {\r",
          "         var reason = \"Tool execution failed\";\r",
          "         if (jsonData.result.content && jsonData.result.content.length > 0) {\r",
          "             reason += \": \" + jsonData.result.content[0].text;\r",
          "         }\r",
          "         pm.expect.fail(reason);\r",
          "    }\r",
          "});"
        ]
      }
    }
